# Copy this file to .env and fill in real values. Never commit the real .env.

FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# --- MySQL: stores user accounts (database `rvlgeoloc`) -------------------
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=rvlgeoloc

# Optional: overrides everything above with a single connection string.
# MYSQL_DATABASE_URL=mysql+pymysql://user:password@host:3306/rvlgeoloc

# --- PostgreSQL/PostGIS: geological + states reference data ---------------
POSTGIS_USER=postgres
POSTGIS_PASSWORD=
POSTGIS_HOST=localhost
POSTGIS_PORT=5432
POSTGIS_DATABASE=rvlgeoloc_geo

# Optional: overrides everything above with a single connection string.
# POSTGIS_DATABASE_URL=postgresql+psycopg2://user:password@host:5432/rvlgeoloc_geo
